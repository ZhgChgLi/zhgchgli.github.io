---
layout: null
permalink: /search.json
---
{% assign visible_posts = site.posts | where_exp: 'p', 'p.hidden != true' %}
[
{% for post in visible_posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: '%Y-%m-%d' | jsonify }},
    "category": {{ post.categories | first | default: '' | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "cover": {{ post.image.path | default: '' | relative_url | jsonify }},
    "excerpt": {{ post.description | default: post.excerpt | strip_html | strip_newlines | truncate: 200 | jsonify }},
    "body": {{ post.content | strip_html | strip_newlines | truncate: 800 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
